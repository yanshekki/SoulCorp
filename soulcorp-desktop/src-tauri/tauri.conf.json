{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoulCorp",
  "version": "1.0.0",
  "identifier": "hk.ysk.soulcorp.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SoulCorp",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 680,
        "center": true,
        "fullscreen": false,
        "maximized": false,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3MDVBODMzQzJGRDQ2MQpSV1JoMUM4OGcxcHdCc3k4VnZvc1AyNXZXRmdSKzhaR3NWRnllK29YR0N4QU9CbTJjUjZyVVJRdAo=",
      "endpoints": [
        "https://github.com/yanshekki/SoulCorp/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
