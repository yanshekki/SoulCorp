{
  "name": "soulcorp-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_PRODUCT_EDITION=v1 PRODUCT_EDITION=v1 tauri dev",
    "dev:v2": "VITE_PRODUCT_EDITION=v2 PRODUCT_EDITION=v2 tauri dev",
    "dev:web": "vite",
    "dev:web:v2": "VITE_PRODUCT_EDITION=v2 vite",
    "build": "VITE_PRODUCT_EDITION=v1 PRODUCT_EDITION=v1 tsc && VITE_PRODUCT_EDITION=v1 vite build",
    "build:v2": "VITE_PRODUCT_EDITION=v2 PRODUCT_EDITION=v2 tsc && VITE_PRODUCT_EDITION=v2 vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "verify": "pnpm typecheck && pnpm build",
    "acceptance": "node scripts/acceptance-check.mjs",
    "generate:furniture-thumbs": "node scripts/generate-furniture-thumbnails.mjs",
    "generate:furniture-gltf": "node scripts/generate-furniture-gltf.mjs",
    "compress:furniture-ktx2": "node scripts/compress-furniture-ktx2.mjs",
    "import:blender-gltf": "node scripts/import-blender-gltf.mjs",
    "release:bundle": "pnpm build && pnpm tauri build"
  },
  "dependencies": {
    "@near-wallet-selector/core": "^10.1.4",
    "@near-wallet-selector/modal-ui": "^10.1.4",
    "@near-wallet-selector/my-near-wallet": "^10.1.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "near-api-js": "^7.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.185.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.6.0",
    "prisma": "^6.16.2",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af"
}
